FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src ./src
COPY config ./config
RUN mkdir -p /app/data

ENV PYTHONPATH=/app
ENV DATABASE_PATH=/app/data/bmad.db
ENV ENV=production

EXPOSE 8000

CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
