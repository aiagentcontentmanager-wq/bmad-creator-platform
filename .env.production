# BMAD Production Configuration
# Copy to Fly.io: fly secrets set KEY=VALUE

ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Required - generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_BEFORE_DEPLOY

# Database
DATABASE_PATH=/app/data/bmad.db

# AI Providers (optional)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Social APIs (add when needed)
# TELEGRAM_BOT_TOKEN=
# INSTAGRAM_APP_ID=
# TWITTER_API_KEY=
